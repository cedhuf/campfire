# Copy to .env and adjust. Bun auto-loads .env in dev; in production pass these
# through your container runtime / compose `environment:`.

# Port the server listens on.
PORT=3000

# Trust the X-Forwarded-For header for per-IP connection limits.
# Keep "true" ONLY behind a trusted reverse proxy (Caddy/Traefik). Set to
# "false" if the server is directly exposed — XFF is otherwise spoofable, and
# the per-IP limit then keys on the real socket IP instead.
TRUST_PROXY=true

# Max simultaneous connections (global) before new ones are politely refused.
MAX_CONNECTIONS=500

# Max simultaneous connections per IP.
MAX_CONNECTIONS_PER_IP=10

# Max chat message length in characters. Longer messages are rejected server-side.
MSG_MAX_LENGTH=140

# Minimum delay between two messages from the same connection, in milliseconds.
MSG_RATE_LIMIT_MS=2200

# Optional access password. Leave empty to disable (default). When set, visitors
# must enter this password before joining (validated over the WebSocket).
ACCESS_PASSWORD=

# Timezone used for the day/night cycle and the clock displayed in the UI.
# Accepts any IANA timezone name (e.g. Europe/Paris, America/New_York, UTC).
# When unset, the server's local timezone is used (depends on the container/host
# tz config). Set this explicitly so the displayed time matches the wall-clock
# you expect, regardless of where the container runs.
TZ=Europe/Paris
